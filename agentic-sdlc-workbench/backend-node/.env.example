# Agentic SDLC Workbench — backend-node environment variables
# Copy to .env in this directory and fill in real values. Never commit .env.

# --- Server ---
PORT=8000                          # HTTP port the Express server listens on

# --- AI providers ---
ANTHROPIC_API_KEY=sk-ant-xxxxx      # Claude API key — powers all ingestion/reconciliation/AI features.
                                     # Leave empty to run in deterministic "stub mode" (used by the test suite).
OPENAI_API_KEY=sk-xxxxx             # OpenAI API key — Whisper transcription for audio document ingest only.

# --- ServiceNow connection (dev convenience; normally set per-project via the Admin UI) ---
SN_INSTANCE=dev12345.service-now.com   # ServiceNow instance hostname for sync/capture
SN_USER=admin                          # ServiceNow integration user
SN_PASSWORD=changeme                   # ServiceNow integration user password
SN_INSECURE_TLS=false                  # true = disable outbound TLS cert verification (needed behind
                                        # a corporate SSL-inspection proxy). Prefer NODE_EXTRA_CA_CERTS instead.

# --- Database & security ---
ASDLC_DB_PATH=./asdlc.db            # Override path to the SQLite DB file (default: backend-node/asdlc.db)
ASDLC_ENCRYPT_KEY=change-me-to-a-long-random-passphrase   # Encrypts stored ServiceNow passwords at rest
                                     # (AES-256-GCM). Unset = passwords stored in plaintext with a warning.

# --- Optional: local ServiceNow design wiki (AI context injection) ---
WIKI_DIR=C:\path\to\wiki            # Local folder of wiki pages injected as extra AI context. Optional —
                                     # the app runs fine without it.

# --- ServiceNow capture/sync tuning (all optional — sane defaults if unset) ---
SN_CAPTURE_PAGE_SIZE=1000           # REST page size per capture request
SN_CAPTURE_MAX_ROWS=50000           # Hard per-surface row ceiling during capture/sync
SN_REF_RESOLVE_MAX_IDS=200          # Cap on distinct referenced IDs resolved per reference-resolution pass
SN_OPEN_ENDED_ROW_CAP=30            # Cap on rows pulled per table during "open-ended" platform-wide discovery
SN_REF_GRAPH_TABLE_CAP=150          # Cap on tables scanned when building the sys_dictionary reference graph
SN_ASSESS_CAP_GREEN=400             # Artifact-count threshold for a "comfortable" scope-size rating
SN_ASSESS_CAP_YELLOW=2000           # Artifact-count threshold for a "large but doable" scope-size rating
SN_MIN_FAMILY=                      # Optional hard floor on ServiceNow release family (e.g. "washington").
                                     # Empty = no floor (capability-detection only).

# --- Misc ---
REVIEW_DEBOUNCE_MS=45000            # Debounce window (ms) for the background AI quality-review queue
